# Copy this to `.env` (same directory as docker-compose.yml) and fill in
# real values - docker compose loads `.env` automatically. This is a
# separate, server-side `.env` from the one `Config`/the desktop UI reads
# for a *client* pointed at a remote store (see `.env.example`).

# Credentials the API server should require from clients (the desktop UI's
# Settings dialog, pdbscanner.py, or the client library's WebPDBClient all
# authenticate with these same values against a remote store).
PH_STORE_USER=changeme
PH_STORE_PASS=changeme

# Perceptual hash size - larger is more detailed/precise duplicate
# detection, but costs more CPU/memory/bandwidth. 70 is a reasonable
# default; only change this if you know you want to.
PH_HASH_SIZE=70

# Token for the Cloudflare Tunnel sidecar (see docker-compose.yml) - create
# a tunnel in the Cloudflare Zero Trust dashboard (Networks > Tunnels >
# Create a tunnel > Docker) with a public hostname routed to
# http://photodb:80, then paste the token it gives you here.
CLOUDFLARE_TUNNEL_TOKEN=changeme
